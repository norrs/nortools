{
  "name": "nortools-docs-site",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "node scripts/generate-tool-reference.mjs && hugo server --bind 127.0.0.1 --baseURL http://localhost/nortools/ --disableLiveReload",
    "docs:generate": "node scripts/generate-tool-reference.mjs",
    "docs:capture": "node scripts/capture-command-output.mjs",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:build": "node scripts/generate-tool-reference.mjs && node scripts/check-docs.mjs && hugo --minify"
  },
  "devDependencies": {
    "hugo-bin": "^0.149.2"
  }
}
